# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id_here
DISCORD_SOURCE_CHANNEL_IDS=channel_id_1,channel_id_2,channel_id_3
DISCORD_DIGEST_CHANNEL_ID=digest_channel_id_here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Security
CRON_SECRET=generate_a_random_secret_here

# Behavior (optional)
LOOKBACK_HOURS=48

# State storage: json | upstash | vercel-kv
STATE_STORAGE_MODE=json

# If STATE_STORAGE_MODE=upstash
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# If STATE_STORAGE_MODE=vercel-kv
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
